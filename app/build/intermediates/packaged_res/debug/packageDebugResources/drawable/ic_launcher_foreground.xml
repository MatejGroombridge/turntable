<?xml version="1.0" encoding="utf-8"?>
<!--
    Default launcher icon foreground shared by all apps in the family: a clean
    3x3 grid of dots, drawn in white at the centre of the adaptive-icon
    viewport. Replace this file per-app when you have a real glyph.

    Geometry: nine 14-unit-diameter circles laid out on a 3x3 grid with 16-unit
    centres, sitting within the centre 48x48 region of the 108x108 launcher
    viewport. That leaves ~30 units of padding on each side, well inside the
    adaptive-icon safe zone, so OEM icon-shape masks (circle, squircle,
    teardrop, etc.) won't clip into it.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Row 1 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M 38,38 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 54,38 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 70,38 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />

    <!-- Row 2 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M 38,54 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 54,54 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 70,54 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />

    <!-- Row 3 -->
    <path android:fillColor="#FFFFFF"
        android:pathData="M 38,70 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 54,70 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
    <path android:fillColor="#FFFFFF"
        android:pathData="M 70,70 m -7,0 a 7,7 0 1,0 14,0 a 7,7 0 1,0 -14,0" />
</vector>
